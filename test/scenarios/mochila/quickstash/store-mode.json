{
  "name": "mochila-quickstash-store-mode",
  "setup": [
    { "action": "run_scenario", "scenario": "test/scenarios/mochila/fixtures/container-line.json" }
  ],
  "steps": [
    { "action": "assert_command_success", "command": "/item replace block 2 200 0 container.0 with minecraft:cobblestone 1" },
    { "action": "assert_command_success", "command": "/item replace entity @s weapon.mainhand with mochila:leather_backpack[mochila:quickstash_mode=1,minecraft:container=[{slot:0,item:{id:\"minecraft:cobblestone\",count:16}},{slot:1,item:{id:\"minecraft:oak_log\",count:8}}]]" },
    { "action": "assert_command_success", "command": "/mochila debug quickstash 2 200 0 north", "expectOutputContains": ["Stored 16 matching items in Chest"] },
    { "action": "wait_ms", "durationMs": 250 },
    { "action": "command", "command": "/data get block 2 200 0 Items", "expectOutputContains": ["minecraft:cobblestone"] }
  ],
  "cleanup": [
    { "action": "command", "command": "/clear @s" },
    { "action": "command", "command": "/setblock 2 200 0 minecraft:air replace" }
  ]
}
