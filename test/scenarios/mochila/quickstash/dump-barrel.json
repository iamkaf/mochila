{
  "name": "mochila-quickstash-dump-barrel",
  "setup": [
    { "action": "run_scenario", "scenario": "test/scenarios/mochila/fixtures/container-line.json" }
  ],
  "steps": [
    { "action": "assert_command_success", "command": "/item replace entity @s weapon.mainhand with mochila:iron_backpack[minecraft:container=[{slot:0,item:{id:\"minecraft:dirt\",count:32}}]]" },
    { "action": "assert_command_success", "command": "/mochila debug quickstash 4 200 0 up", "expectOutputContains": ["Stored 32 items in Barrel"] },
    { "action": "wait_ms", "durationMs": 250 },
    { "action": "command", "command": "/data get block 4 200 0 Items", "expectOutputContains": ["minecraft:dirt"] }
  ],
  "cleanup": [
    { "action": "command", "command": "/clear @s" },
    { "action": "command", "command": "/setblock 4 200 0 minecraft:air replace" }
  ]
}
