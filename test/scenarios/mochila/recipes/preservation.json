{
  "name": "mochila-recipes-preservation",
  "setup": [
    { "action": "run_scenario", "scenario": "test/scenarios/mochila/fixtures/clean-room.json" }
  ],
  "steps": [
    { "action": "assert_command_success", "command": "/mochila debug sample mochila:leather_backpack" },
    { "action": "assert_command_success", "command": "/mochila debug recipe color minecraft:red_dye" },
    { "action": "assert_command_success", "command": "/mochila debug assert-sample mochila:red_leather_backpack" },

    { "action": "assert_command_success", "command": "/mochila debug sample mochila:red_leather_backpack" },
    { "action": "assert_command_success", "command": "/mochila debug recipe upgrade minecraft:iron_ingot" },
    { "action": "assert_command_success", "command": "/mochila debug assert-sample mochila:red_iron_backpack" },
    { "action": "assert_command_success", "command": "/mochila debug recipe upgrade minecraft:gold_ingot" },
    { "action": "assert_command_success", "command": "/mochila debug assert-sample mochila:red_gold_backpack" },
    { "action": "assert_command_success", "command": "/mochila debug recipe upgrade minecraft:diamond" },
    { "action": "assert_command_success", "command": "/mochila debug assert-sample mochila:red_diamond_backpack" },

    { "action": "assert_command_success", "command": "/mochila debug sample mochila:red_diamond_backpack" },
    { "action": "assert_command_success", "command": "/mochila debug recipe smith-netherite" },
    { "action": "assert_command_success", "command": "/mochila debug assert-sample mochila:red_netherite_backpack" },

    { "action": "assert_command_success", "command": "/mochila debug sample mochila:leather_backpack" },
    { "action": "assert_command_success", "command": "/mochila debug recipe assert-invalid-upgrade minecraft:gold_ingot" },
    { "action": "assert_command_success", "command": "/mochila debug sample mochila:netherite_backpack" },
    { "action": "assert_command_success", "command": "/mochila debug recipe assert-invalid-upgrade minecraft:diamond" }
  ],
  "cleanup": [
    { "action": "command", "command": "/clear @s" }
  ]
}
