    { "action": "wait_for_block", "x": 2, "y": 200, "z": 0, "blockId": "minecraft:chest", "timeoutMs": 3000 },
    { "action": "wait_for_block", "x": 4, "y": 200, "z": 0, "blockId": "minecraft:barrel", "timeoutMs": 3000 },
    { "action": "wait_for_block", "x": 6, "y": 200, "z": 0, "blockId": "minecraft:trapped_chest", "timeoutMs": 3000 }
  ]
}
