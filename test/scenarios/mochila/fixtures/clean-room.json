{
  "name": "mochila-fixture-clean-room",
  "steps": [
    { "action": "command", "command": "/gamemode creative" },
    { "action": "command", "command": "/difficulty peaceful" },
    { "action": "command", "command": "/weather clear" },
    { "action": "command", "command": "/time set day" },
    { "action": "command", "command": "/effect clear @s" },
    { "action": "command", "command": "/clear @s" },
    { "action": "clear_nearby_entities", "radius": 32, "entityType": "minecraft:item", "timeoutMs": 5000 },
    { "action": "command", "command": "/execute in minecraft:overworld run tp @s 0.5 200 0.5 0 20" },
    { "action": "command", "command": "/execute in minecraft:overworld run fill -10 199 -10 10 207 10 minecraft:air replace" },
    { "action": "command", "command": "/execute in minecraft:overworld run fill -10 199 -10 10 199 10 minecraft:glass replace" },
    { "action": "wait_for_block", "x": 0, "y": 199, "z": 0, "blockId": "minecraft:glass", "timeoutMs": 3000 }
  ]
}
