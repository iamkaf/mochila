{
  "name": "mochila-backpack-container-component-persistence",
  "setup": [
    { "action": "run_scenario", "scenario": "test/scenarios/mochila/fixtures/clean-room.json" }
  ],
  "steps": [
    { "action": "assert_command_success", "command": "/item replace entity @s weapon.mainhand with mochila:leather_backpack[minecraft:container=[{slot:0,item:{id:\"minecraft:cobblestone\",count:16}},{slot:1,item:{id:\"minecraft:oak_log\",count:8}}]]" },
    { "action": "use_item", "hand": "main_hand" },
    { "action": "wait_for_screen", "title": "Leather Backpack", "titleContains": true, "timeoutMs": 5000 },
    { "action": "close_menu" },
    { "action": "assert_inventory_item", "itemId": "mochila:leather_backpack" }
  ],
  "cleanup": [
    { "action": "command", "command": "/clear @s" }
  ]
}
