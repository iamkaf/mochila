{
  "name": "mochila-backpack-keybind-open-and-mode-component",
  "setup": [
    { "action": "run_scenario", "scenario": "test/scenarios/mochila/fixtures/clean-room.json" }
  ],
  "steps": [
    { "action": "assert_command_success", "command": "/item replace entity @s weapon.mainhand with mochila:leather_backpack" },
    { "action": "key_state", "key": 66, "pressed": true },
    { "action": "key_state", "key": 66, "pressed": false },
    { "action": "wait_for_screen", "title": "Leather Backpack", "titleContains": true, "timeoutMs": 5000 },
    { "action": "close_menu" },
    { "action": "assert_command_success", "command": "/item replace entity @s weapon.mainhand with mochila:leather_backpack[mochila:quickstash_mode=1]" },
    { "action": "assert_command_success", "command": "/execute if items entity @s weapon.mainhand mochila:leather_backpack[mochila:quickstash_mode=1]" }
  ],
  "cleanup": [
    { "action": "command", "command": "/clear @s" }
  ]
}
