{
  "name": "mochila-backpack-open-tier-sizes",
  "setup": [
    { "action": "run_scenario", "scenario": "test/scenarios/mochila/fixtures/clean-room.json" }
  ],
  "steps": [
    { "action": "assert_command_success", "command": "/item replace entity @s weapon.mainhand with mochila:leather_backpack" },
    { "action": "use_item", "hand": "main_hand" },
    { "action": "wait_for_screen", "title": "Leather Backpack", "titleContains": true, "timeoutMs": 5000 },
    { "action": "close_menu" },
    { "action": "assert_command_success", "command": "/item replace entity @s weapon.mainhand with mochila:iron_backpack" },
    { "action": "use_item", "hand": "main_hand" },
    { "action": "wait_for_screen", "title": "Iron Backpack", "titleContains": true, "timeoutMs": 5000 },
    { "action": "close_menu" },
    { "action": "assert_command_success", "command": "/item replace entity @s weapon.mainhand with mochila:gold_backpack" },
    { "action": "use_item", "hand": "main_hand" },
    { "action": "wait_for_screen", "title": "Gold Backpack", "titleContains": true, "timeoutMs": 5000 },
    { "action": "close_menu" },
    { "action": "assert_command_success", "command": "/item replace entity @s weapon.mainhand with mochila:diamond_backpack" },
    { "action": "use_item", "hand": "main_hand" },
    { "action": "wait_for_screen", "title": "Diamond Backpack", "titleContains": true, "timeoutMs": 5000 },
    { "action": "close_menu" },
    { "action": "assert_command_success", "command": "/item replace entity @s weapon.mainhand with mochila:netherite_backpack" },
    { "action": "use_item", "hand": "main_hand" },
    { "action": "wait_for_screen", "title": "Netherite Backpack", "titleContains": true, "timeoutMs": 5000 },
    { "action": "close_menu" },
    { "action": "wait_for_no_screen", "timeoutMs": 3000 }
  ],
  "cleanup": [
    { "action": "command", "command": "/clear @s" }
  ]
}
