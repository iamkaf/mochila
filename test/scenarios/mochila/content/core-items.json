{
  "name": "mochila-content-core-items",
  "setup": [
    { "action": "run_scenario", "scenario": "test/scenarios/mochila/fixtures/clean-room.json" }
  ],
  "steps": [
    { "action": "assert_command_success", "command": "/give @s mochila:leather_backpack" },
    { "action": "assert_command_success", "command": "/give @s mochila:iron_backpack" },
    { "action": "assert_command_success", "command": "/give @s mochila:gold_backpack" },
    { "action": "assert_command_success", "command": "/give @s mochila:diamond_backpack" },
    { "action": "assert_command_success", "command": "/give @s mochila:netherite_backpack" },
    { "action": "assert_command_success", "command": "/give @s mochila:ender_backpack" },
    { "action": "assert_inventory_item", "itemId": "mochila:leather_backpack" },
    { "action": "assert_inventory_item", "itemId": "mochila:iron_backpack" },
    { "action": "assert_inventory_item", "itemId": "mochila:gold_backpack" },
    { "action": "assert_inventory_item", "itemId": "mochila:diamond_backpack" },
    { "action": "assert_inventory_item", "itemId": "mochila:netherite_backpack" },
    { "action": "assert_inventory_item", "itemId": "mochila:ender_backpack" }
  ],
  "cleanup": [
    { "action": "command", "command": "/clear @s" }
  ]
}
